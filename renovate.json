{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "labels": ["dependencies", "renovate", "docs"],
  "enabledManagers": ["regex"],
  "regexManagers": [
    {
      "description": "Container image tags in ModuLix docs",
      "fileMatch": ["^30-modulix/.*\\.md$"],
      "matchStrings": [
        "(?<depName>[a-z0-9.-]+/[a-z0-9._/-]+):(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "description": "Group container image updates in docs",
      "matchDatasources": ["docker"],
      "groupName": "docs container images"
    }
  ]
}
